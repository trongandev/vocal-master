rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL BY DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    // AUTH HELPERS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // VALIDATION HELPERS
    function isValidVocalEvaluation(data) {
      return data.userId == request.auth.uid 
          && data.analysisResult is string 
          && data.analysisResult.size() <= 10000
          && data.createdAt == request.time;
    }

    function isValidUserProfile(data) {
      return data.userId == request.auth.uid
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && (data.updatedAt == request.time);
    }

    function isValidSingingHistory(data) {
      return data.userId == request.auth.uid 
          && data.songId is string 
          && data.score is number 
          && (data.songTitle == null || data.songTitle is string)
          && (data.songArtist == null || data.songArtist is string)
          && (data.aiFeedback == null || data.aiFeedback is string);
    }

    // COLLECTIONS
    match /singingHistory/{historyId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSingingHistory(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && isValidSingingHistory(request.resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiFeedback']);
    }

    match /favoriteSongs/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /vocalEvaluations/{evaluationId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /songs/{songId} {
      allow get: if (isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.status == 'public')) || isAdmin();
      allow list: if (isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.status == 'public')) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow update: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      
      match /noteChunks/{chunkId} {
         allow get: if isSignedIn();
         allow list: if isSignedIn();
         allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
         allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
         allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      }
    }
  }
}
